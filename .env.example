# Copy this file to .env and fill values from AWS Learner Lab credentials.
# Docker Compose reads .env automatically from the project root.

# Required for AWS SDK auth in containers
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Required when using temporary credentials (Learner Lab usually uses these)
AWS_SESSION_TOKEN=your_session_token

# Region used by the SDK/client
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
